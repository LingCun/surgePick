{
  "name": "surge-pick",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/build-tickers-index.mjs && astro build && node scripts/fix-vercel-runtime.mjs",
    "preview": "astro preview",
    "scan:regime": "node scripts/scan-regime.mjs",
    "ingest:regime": "node scripts/ingest-regime.mjs",
    "ingest:prices": "node scripts/ingest-prices.mjs",
    "ingest:tickers": "node scripts/ingest-tickers.mjs",
    "backfill:prices": "node scripts/backfill-prices.mjs",
    "backfill:regime": "node scripts/backfill-regime.mjs",
    "build:universe": "node scripts/build-universe.mjs",
    "build:index": "node scripts/build-tickers-index.mjs",
    "scan": "npm run scan:regime && npm run ingest:regime && npm run ingest:prices",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.4",
    "@astrojs/vercel": "^7.8.2",
    "@libsql/client": "^0.17.3",
    "astro": "^4.16.18",
    "dotenv": "^17.4.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}

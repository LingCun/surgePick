---
---
<script>
  type ApiResp = {
    ticker: { ticker: string; name_kr: string|null; name_en: string|null; market: string; exchange: string };
    today_close: number;
    context: { label: string; vix: number|null; vix_band: string; case_count: number; fallback: boolean; error: string|null };
    history: { date: string; open: number; close: number }[];
    forecast: { d: number; date: string; median: number; lo: number; hi: number }[];
  };

  const resultRoot = document.getElementById('sim-result') as HTMLElement;
  let lastSelectedTicker: string | null = null;
  let currentHorizon = 30;

  window.addEventListener('sim:run', async (ev: Event) => {
    const { ticker } = (ev as CustomEvent).detail;
    lastSelectedTicker = ticker.ticker;
    syncUrl();
    await runAndRender(currentHorizon);
  });

  window.addEventListener('sim:horizon', async (ev: Event) => {
    currentHorizon = (ev as CustomEvent).detail.horizon;
    syncHorizonButtons(currentHorizon);
    syncUrl();
    if (lastSelectedTicker) await runAndRender(currentHorizon);
  });

  function syncUrl() {
    if (!lastSelectedTicker) return;
    const p = new URLSearchParams();
    p.set('ticker', lastSelectedTicker);
    p.set('h', String(currentHorizon));
    history.replaceState(null, '', `${location.pathname}?${p.toString()}`);
  }

  function syncHorizonButtons(hz: number) {
    document.querySelectorAll('[data-hz]').forEach((btn) => {
      const el = btn as HTMLElement;
      const active = Number(el.dataset.hz) === hz;
      el.classList.toggle('hz-active', active);
    });
  }

  async function runAndRender(horizon: number) {
    if (!lastSelectedTicker) return;
    resultRoot.classList.remove('hidden');
    resultRoot.innerHTML = `
      <div class="flex items-center justify-center py-12 text-slate-400 text-sm gap-2">
        <span class="inline-block w-3 h-3 rounded-full bg-cyan-500 animate-pulse"></span>
        데이터 불러오는 중...
      </div>`;

    const res = await fetch(`/api/ticker?id=${encodeURIComponent(lastSelectedTicker)}&horizon=${horizon}`);
    if (!res.ok) {
      resultRoot.innerHTML = `
        <div class="bg-rose-950/40 border border-rose-800/60 rounded-xl p-4 text-rose-300 text-sm">
          조회 실패 (HTTP ${res.status})
        </div>`;
      return;
    }
    const data: ApiResp = await res.json();

    resultRoot.innerHTML = renderChartSection(data) + renderPriceTable(data);
    fillPriceTable(data);
    window.dispatchEvent(new CustomEvent('sim:rendered', { detail: { data, horizon } }));
    // 차트로 포커스 이동 (헤더 카드 상단에 맞춤)
    requestAnimationFrame(() => {
      resultRoot.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  function renderChartSection(d: ApiResp) {
    const shortTicker = d.ticker.ticker.replace(/\.[A-Z]+$/, '');
    const rawName = d.ticker.name_kr ?? d.ticker.name_en ?? shortTicker;
    const name = rawName.split(/[\r\n]+/).map((s) => s.trim()).filter(Boolean).pop() ?? shortTicker;
    const flag = d.ticker.market === 'KR' ? '🇰🇷' : '🇺🇸';
    const currency = d.ticker.market === 'KR' ? '₩' : '$';
    const fmt = (n: number) => n.toLocaleString(d.ticker.market === 'KR' ? 'ko-KR' : 'en-US', { maximumFractionDigits: 2 });
    const noForecast = d.forecast.length === 0;
    const errMsg = noForecast
      ? `<div class="absolute inset-0 flex items-center justify-center pointer-events-none z-10">
           <div class="bg-slate-950/90 backdrop-blur border border-amber-700/60 rounded-xl px-5 py-3 text-amber-300 text-sm text-center shadow-xl">
             <div class="font-semibold">예측 불가</div>
             <div class="text-xs text-slate-400 mt-1">유사 사례 표본 부족 — regime 적재 누적 대기</div>
           </div>
         </div>`
      : '';

    const labelKo = { bull: '강세장', neutral: '횡보', bear: '약세장' }[d.context.label] ?? d.context.label;
    const bandKo = { low: '낮음', mid: '보통', high: '높음' }[d.context.vix_band] ?? d.context.vix_band;
    const labelColor = d.context.label === 'bull' ? 'text-emerald-400 bg-emerald-950/40 border-emerald-800/50'
      : d.context.label === 'bear' ? 'text-rose-400 bg-rose-950/40 border-rose-800/50'
      : 'text-slate-300 bg-slate-800/40 border-slate-700/50';

    // 예측 신뢰도: case_count 30 미만은 표본 부족 워닝.
    const lowConfidence = !noForecast && d.context.case_count < 30;
    const warningBanner = lowConfidence
      ? `<div class="bg-amber-950/30 border border-amber-700/40 rounded-xl px-4 py-2.5 text-xs text-amber-300 flex items-start gap-2">
           <span class="text-base leading-none mt-0.5">⚠</span>
           <span><span class="font-semibold">신뢰도 낮음</span> — 유사 사례 ${d.context.case_count}건. 표본이 작아 예측이 한쪽으로 치우칠 수 있어요.</span>
         </div>`
      : '';

    return `
      <section class="forecast-chart space-y-3">
        <header class="bg-slate-900/60 border border-slate-800 rounded-xl p-4 flex items-center justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-2xl">${flag}</span>
            <div class="min-w-0">
              <div class="font-bold text-lg truncate">${name}</div>
              <div class="text-xs text-slate-500 font-mono">${shortTicker} · ${d.ticker.exchange}</div>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <div class="text-right">
              <div class="text-xl font-bold tabular-nums">${currency}${fmt(d.today_close)}</div>
              <div class="text-[10px] text-slate-500 uppercase tracking-wide">현재가</div>
            </div>
            <button id="sim-share" type="button" aria-label="공유" class="w-9 h-9 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white flex items-center justify-center transition" title="공유 링크 복사">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </button>
          </div>
        </header>

        <div class="flex flex-wrap items-center gap-2 text-xs">
          <span class="px-2 py-1 rounded-full border ${labelColor}">${labelKo}</span>
          <span class="px-2 py-1 rounded-full border border-slate-700/50 text-slate-400 bg-slate-800/40">변동성 ${bandKo}</span>
          <span class="px-2 py-1 rounded-full border border-slate-700/50 text-slate-400 bg-slate-800/40">유사사례 ${d.context.case_count}건</span>
          ${d.context.fallback ? '<span class="px-2 py-1 rounded-full border border-amber-700/40 text-amber-400 bg-amber-950/30">폴백 매칭</span>' : ''}
        </div>

        ${warningBanner}

        <div class="relative h-72 md:h-96 bg-gradient-to-br from-slate-900 to-slate-950 rounded-xl border border-slate-800 p-3">
          <canvas id="forecast-canvas"></canvas>
          ${errMsg}
        </div>

        <div class="flex justify-center gap-5 text-xs text-slate-400 flex-wrap">
          <span class="flex items-center gap-1.5"><span class="inline-block w-4 h-0.5 bg-sky-400"></span>과거 1달 실제</span>
          ${noForecast ? '' : `
            <span class="flex items-center gap-1.5"><span class="inline-block w-4 h-0 border-t-2 border-dashed border-amber-400"></span>예측 메디안</span>
            <span class="flex items-center gap-1.5"><span class="inline-block w-4 h-2.5" style="background:rgba(251,191,36,0.2)"></span>예측 p25~p75</span>
          `}
        </div>
      </section>
    `;
  }

  function renderPriceTable(d: ApiResp) {
    return `
      <section class="price-table bg-slate-900/40 border border-slate-800 rounded-xl overflow-hidden">
        <header class="px-4 py-3 border-b border-slate-800 flex items-center justify-between">
          <h2 class="text-sm font-semibold text-slate-300">최근 가격</h2>
        </header>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[11px] uppercase tracking-wide text-slate-500 bg-slate-900/40">
              <tr>
                <th class="py-2.5 px-4 text-left font-medium">날짜</th>
                <th class="py-2.5 px-3 text-right font-medium">시가</th>
                <th class="py-2.5 px-3 text-right font-medium">종가</th>
                <th class="py-2.5 px-4 text-right font-medium">변동</th>
              </tr>
            </thead>
            <tbody data-pt-body></tbody>
          </table>
        </div>
      </section>
    `;
  }

  function fillPriceTable(d: ApiResp) {
    const body = resultRoot.querySelector('[data-pt-body]') as HTMLElement;
    const fmt = (n: number) => n.toLocaleString(d.ticker.market === 'KR' ? 'ko-KR' : 'en-US', { maximumFractionDigits: 2 });

    const last10 = d.history.slice(-10).reverse();
    body.innerHTML = last10
      .map((p, i) => {
        const prev = i === last10.length - 1 ? p.close : last10[i + 1].close;
        const change = ((p.close - prev) / prev) * 100;
        const up = change > 0, down = change < 0;
        const color = up ? 'text-rose-400' : down ? 'text-sky-400' : 'text-slate-500';
        const arrow = up ? '▲' : down ? '▼' : '·';
        return `<tr class="border-b border-slate-800/40 last:border-0 hover:bg-slate-800/30 transition">
          <td class="py-2.5 px-4 font-mono text-xs text-slate-400">${p.date}</td>
          <td class="py-2.5 px-3 text-right tabular-nums text-slate-300">${fmt(p.open)}</td>
          <td class="py-2.5 px-3 text-right tabular-nums font-semibold text-slate-100">${fmt(p.close)}</td>
          <td class="py-2.5 px-4 text-right tabular-nums ${color} font-medium">${arrow} ${change >= 0 ? '+' : ''}${change.toFixed(2)}%</td>
        </tr>`;
      })
      .join('');
  }

  // horizon 토글 (sim.astro 의 #horizon-picker 버튼이 트리거)
  document.body.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('[data-hz]');
    if (btn) {
      const hz = Number((btn as HTMLElement).dataset.hz);
      window.dispatchEvent(new CustomEvent('sim:horizon', { detail: { horizon: hz } }));
      return;
    }
    if (target.closest('#sim-share')) {
      const url = location.href;
      const shareBtn = target.closest('#sim-share') as HTMLButtonElement;
      const reset = (txt: string) => {
        const original = shareBtn.getAttribute('aria-label') ?? '공유';
        shareBtn.setAttribute('aria-label', txt);
        shareBtn.title = txt;
        setTimeout(() => { shareBtn.setAttribute('aria-label', original); shareBtn.title = '공유 링크 복사'; }, 1500);
      };
      // Web Share API 우선
      if (navigator.share) {
        navigator.share({ url }).catch(() => navigator.clipboard?.writeText(url).then(() => reset('링크 복사됨')));
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(() => reset('링크 복사됨')).catch(() => reset('복사 실패'));
      }
    }
  });

  // ---- ForecastChart ----
  declare const Chart: any;

  let chart: any = null;
  let drawId = 0;

  window.addEventListener('sim:rendered', (ev: Event) => {
    const { data } = (ev as CustomEvent).detail;
    drawChart(data);
  });

  // "오늘" 세로선 + 영역 음영 plugin (lastHistoryDate 를 데이터셋에 stash)
  const todayMarkerPlugin = {
    id: 'todayMarker',
    afterDatasetsDraw(chart: any) {
      const todayDate = chart.options._todayDate;
      if (!todayDate) return;
      const xScale = chart.scales.x;
      const yScale = chart.scales.y;
      const xPos = xScale.getPixelForValue(new Date(todayDate).getTime());
      if (xPos == null || isNaN(xPos)) return;
      const { ctx } = chart;
      ctx.save();
      // 예측 영역 배경 음영 (오늘 ~ 차트 우측)
      ctx.fillStyle = 'rgba(251,191,36,0.04)';
      ctx.fillRect(xPos, yScale.top, xScale.right - xPos, yScale.bottom - yScale.top);
      // 세로 점선
      ctx.strokeStyle = '#fbbf24';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([4, 4]);
      ctx.beginPath();
      ctx.moveTo(xPos, yScale.top);
      ctx.lineTo(xPos, yScale.bottom);
      ctx.stroke();
      ctx.setLineDash([]);
      // "오늘" 라벨
      ctx.fillStyle = '#fbbf24';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('오늘', xPos, yScale.top - 4);
      ctx.restore();
    },
  };

  function drawChart(data: ApiResp) {
    const canvas = document.getElementById('forecast-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const myId = ++drawId;   // 이전 draw 의 in-flight tick 무효화
    if (chart) chart.destroy();

    const ctx = canvas.getContext('2d')!;

    // x-axis lock: 과거 시작일 ~ 예측 마지막일 (forecast 없으면 history 끝)
    const lastHistoryDate = data.history.length > 0 ? data.history[data.history.length - 1].date : null;
    const xMin = data.history.length > 0 ? data.history[0].date : null;
    const xMax = data.forecast.length > 0 ? data.forecast[data.forecast.length - 1].date : lastHistoryDate;
    // "오늘" 마커: forecast 있으면 forecast[0].date, 없으면 history 마지막 날
    const todayDate = data.forecast.length > 0 ? data.forecast[0].date : lastHistoryDate;

    // y-axis lock: history + forecast 의 모든 값 범위 (8% 패딩)
    const yVals: number[] = [];
    data.history.forEach((p) => yVals.push(p.close));
    data.forecast.forEach((p) => { yVals.push(p.lo, p.hi); });
    const yMin = yVals.length ? Math.min(...yVals) : 0;
    const yMax = yVals.length ? Math.max(...yVals) : 1;
    const pad = (yMax - yMin) * 0.08 || yMax * 0.02;

    chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: [],
        datasets: [
          { label: '과거 실제',     data: [], borderColor: '#38bdf8', backgroundColor: 'transparent', borderWidth: 2.5, fill: false, pointRadius: 0, tension: 0.2 },
          { label: '예측 메디안',   data: [], borderColor: '#fbbf24', backgroundColor: 'transparent', borderWidth: 2.5, borderDash: [6, 4], fill: false, pointRadius: 0, tension: 0.2 },
          { label: '예측 p25-p75', data: [], borderColor: 'transparent', backgroundColor: 'rgba(251,191,36,0.18)', fill: '-1', pointRadius: 0 },
          { label: '_p25 hidden',  data: [], borderColor: 'transparent', backgroundColor: 'transparent', fill: false, pointRadius: 0, showLine: false, hidden: false },
        ],
      },
      options: {
        animation: false,
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        _todayDate: todayDate,
        plugins: {
          legend: { display: false },
          tooltip: { mode: 'index', intersect: false },
        },
        scales: {
          x: {
            type: 'time',
            min: xMin ?? undefined,
            max: xMax ?? undefined,
            time: { unit: 'week' },
            ticks: { color: '#64748b' },
            grid: { color: '#1e293b' },
          },
          y: {
            min: yMin - pad,
            max: yMax + pad,
            ticks: { color: '#64748b' },
            grid: { color: '#1e293b' },
          },
        },
      } as any,
      plugins: [todayMarkerPlugin],
    });

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const allPoints = [
      ...data.history.map((p) => ({ date: p.date, isHistory: true, value: p.close })),
      ...data.forecast.slice(1).map((p) => ({ date: p.date, isHistory: false, median: p.median, lo: p.lo, hi: p.hi })),
    ];

    if (reduceMotion) {
      allPoints.forEach((p) => pushPoint(p));
      chart.update('none');
      return;
    }

    // 천천히: 5초. 데이터양 무관 일정 속도.
    const totalMs = 5000;
    const msPerPoint = totalMs / Math.max(allPoints.length, 1);
    let i = 0;
    let lastTs = performance.now();

    function tick(now: number) {
      if (myId !== drawId) return;   // 새 draw 호출돼서 무효 — 점 추가 중단
      while (now - lastTs >= msPerPoint && i < allPoints.length) {
        pushPoint(allPoints[i]);
        i++;
        lastTs += msPerPoint;
      }
      chart.update('none');
      if (i < allPoints.length) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    function pushPoint(p: any) {
      chart.data.labels.push(p.date);
      if (p.isHistory) {
        chart.data.datasets[0].data.push(p.value);
        chart.data.datasets[1].data.push(null);
        chart.data.datasets[2].data.push(null);
        chart.data.datasets[3].data.push(null);
      } else {
        chart.data.datasets[0].data.push(null);
        chart.data.datasets[1].data.push(p.median);
        chart.data.datasets[2].data.push(p.hi);
        chart.data.datasets[3].data.push(p.lo);
      }
    }
  }
</script>

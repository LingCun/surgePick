---
---
<div class="ticker-search relative">
  <div class="relative">
    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    </span>
    <input
      id="tk-input"
      type="text"
      autocomplete="off"
      spellcheck="false"
      placeholder="종목명 또는 코드 검색 (예: 삼성전자, AAPL, QQQ)"
      class="w-full pl-11 pr-11 py-3.5 rounded-xl bg-slate-900/60 text-slate-100 border border-slate-800 focus:outline-none focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 placeholder:text-slate-500 transition"
    />
    <button
      id="tk-clear"
      type="button"
      aria-label="입력 지우기"
      class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white flex items-center justify-center transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  <ul
    id="tk-results"
    role="listbox"
    class="hidden absolute z-10 mt-2 w-full max-h-80 overflow-auto rounded-xl bg-slate-900 border border-slate-700 shadow-2xl shadow-slate-950/50"
  ></ul>
  <button
    id="tk-go"
    type="button"
    disabled
    class="mt-3 w-full py-3.5 rounded-xl bg-gradient-to-r from-cyan-600 to-sky-600 hover:from-cyan-500 hover:to-sky-500 disabled:from-slate-800 disabled:to-slate-800 disabled:text-slate-500 text-white font-semibold transition shadow-lg shadow-cyan-900/20 disabled:shadow-none"
  >시뮬레이션 시작</button>
</div>

<script>
  import { search } from '../lib/autocomplete.mjs';

  const input = document.getElementById('tk-input') as HTMLInputElement;
  const results = document.getElementById('tk-results') as HTMLUListElement;
  const goBtn = document.getElementById('tk-go') as HTMLButtonElement;
  const clearBtn = document.getElementById('tk-clear') as HTMLButtonElement;

  function syncClearBtn() {
    clearBtn.classList.toggle('hidden', input.value.length === 0);
  }

  type Item = { ticker: string; name_kr: string | null; name_en: string | null; market: 'KR' | 'US'; exchange: string };

  let index: Item[] = [];
  let selected: Item | null = null;
  let highlight = -1;
  let currentMatches: Item[] = [];

  function cleanName(raw: string, fallback: string) {
    return raw.split(/[\r\n]+/).map((s) => s.trim()).filter(Boolean).pop() ?? fallback;
  }

  fetch('/tickers-index.json').then((r) => r.json()).then((d) => { index = d; });

  function render(matches: Item[]) {
    currentMatches = matches;
    highlight = -1;
    if (matches.length === 0) {
      results.classList.add('hidden');
      return;
    }
    results.innerHTML = matches
      .map((m, i) => {
        const flag = m.market === 'KR' ? '🇰🇷' : '🇺🇸';
        const raw = m.name_kr ?? m.name_en ?? m.ticker;
        const display = cleanName(raw, m.ticker);
        const short = m.ticker.replace(/\.[A-Z]+$/, '');
        const exchangeBadge = m.exchange;
        return `<li role="option" data-i="${i}" class="px-4 py-3 cursor-pointer hover:bg-slate-800/80 flex items-center gap-3 border-b border-slate-800/50 last:border-0 transition">
          <span class="text-lg">${flag}</span>
          <div class="flex-1 min-w-0">
            <div class="font-medium text-slate-100 truncate">${display}</div>
            <div class="text-[11px] text-slate-500 font-mono">${short} · ${exchangeBadge}</div>
          </div>
        </li>`;
      })
      .join('');
    results.classList.remove('hidden');
  }

  function pick(m: Item) {
    selected = m;
    const raw = m.name_kr ?? m.name_en ?? m.ticker;
    input.value = cleanName(raw, m.ticker);
    results.classList.add('hidden');
    goBtn.disabled = false;
    syncClearBtn();
  }

  input.addEventListener('input', () => {
    selected = null;
    goBtn.disabled = true;
    render(search(index, input.value, 8));
    syncClearBtn();
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    selected = null;
    goBtn.disabled = true;
    results.classList.add('hidden');
    syncClearBtn();
    input.focus();
  });

  input.addEventListener('keydown', (e) => {
    if (results.classList.contains('hidden')) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      highlight = Math.min(highlight + 1, currentMatches.length - 1);
      updateHighlight();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      highlight = Math.max(highlight - 1, 0);
      updateHighlight();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (highlight >= 0) pick(currentMatches[highlight]);
    } else if (e.key === 'Escape') {
      results.classList.add('hidden');
    }
  });

  function updateHighlight() {
    [...results.children].forEach((el, i) => {
      el.classList.toggle('bg-slate-800', i === highlight);
    });
  }

  results.addEventListener('click', (e) => {
    const li = (e.target as HTMLElement).closest('li');
    if (!li) return;
    pick(currentMatches[Number((li as HTMLElement).dataset.i)]);
  });

  goBtn.addEventListener('click', () => {
    if (!selected) return;
    window.dispatchEvent(new CustomEvent('sim:run', { detail: { ticker: selected } }));
  });
</script>

---
interface Props {
  entry: {
    id: string;
    market: string;
    ticker: string;
    name: string;
    buyDate: string;
    buyPrice: number;
    currentPrice: number;
    currentDate: string;
    returnPct: number;
    horizon: string;
    holdDays: number;
    matureDate: string;
    status: string;
    sellDate: string | null;
    sellPrice: number | null;
  };
}
const { entry } = Astro.props;

const horizonColor =
  entry.horizon === '단기' ? 'bg-horizon-short/20 text-horizon-short'
  : entry.horizon === '중기' ? 'bg-horizon-mid/20 text-horizon-mid'
  : 'bg-horizon-long/20 text-horizon-long';

const statusColor = entry.status === 'holding'
  ? 'bg-slate-700 text-slate-300'
  : 'bg-teal-500/30 text-teal-300';

const statusLabel = entry.status === 'holding' ? '보유중' : '매도완료';
const flagEmoji = entry.market === 'KR' ? '🇰🇷' : '🇺🇸';
const currency = entry.market === 'KR' ? '원' : '$';
const fmtPrice = (p) => entry.market === 'KR'
  ? p.toLocaleString('ko-KR') + currency
  : currency + p.toFixed(2);

const returnColor = entry.returnPct >= 0 ? 'text-emerald-400' : 'text-red-400';
const returnText = (entry.returnPct >= 0 ? '+' : '') + entry.returnPct.toFixed(2) + '%';

// Days remaining for holdings, or sold info
let bottomNote;
if (entry.status === 'sold') {
  bottomNote = `${entry.sellDate} 매도 (확정)`;
} else {
  const matureTime = new Date(entry.matureDate + 'T00:00:00Z').getTime();
  const now = Date.now();
  const daysLeft = Math.max(0, Math.ceil((matureTime - now) / (1000 * 60 * 60 * 24)));
  bottomNote = `D-${daysLeft} · 만기 ${entry.matureDate}`;
}
---
<a href={`/picks/${entry.id}/`} class="block rounded-2xl bg-slate-900 border border-slate-800 p-4 space-y-2 hover:bg-slate-800 transition-colors">
  <header class="flex items-center justify-between text-xs">
    <span class="text-slate-400">{entry.buyDate}</span>
    <div class="flex items-center gap-2">
      <span class={`px-2 py-0.5 rounded-full font-semibold ${horizonColor}`}>{entry.horizon}</span>
      <span class={`px-2 py-0.5 rounded-full font-semibold ${statusColor}`}>{statusLabel}</span>
    </div>
  </header>
  <h3 class="text-base font-semibold flex items-center gap-2">
    <span aria-hidden="true">{flagEmoji}</span>
    {entry.name}
    <span class="text-xs text-slate-400 font-normal">{entry.ticker}</span>
  </h3>
  <div class="flex items-baseline justify-between">
    <span class="text-sm text-slate-300">{fmtPrice(entry.buyPrice)} → {fmtPrice(entry.currentPrice)}</span>
    <span class={`text-lg font-bold ${returnColor}`}>{returnText}</span>
  </div>
  <p class="text-[11px] text-slate-500">{bottomNote}</p>
</a>

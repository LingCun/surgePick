---
interface Props {
  position: {
    name: string;
    ticker: string;
    market: string;
    shares: number;
    avgCost: number;
    currentPrice: number;
    unrealizedReturn?: number;
    dcaPlan?: boolean;
    distPlan?: boolean;
  };
}

const { position } = Astro.props;
const r = position.unrealizedReturn ?? 0;
const positive = r >= 0;
const colorCls = positive ? 'text-rose-400' : 'text-sky-400';
---

<div class="border-b border-slate-800 last:border-b-0 py-2 px-3 flex items-center gap-4 text-sm text-slate-200">
  <div class="flex-1 min-w-0">
    <div class="font-medium truncate">{position.name}</div>
    <div class="text-slate-500 text-xs">{position.ticker} · {position.market}</div>
  </div>
  <div class="text-right">
    <div>{position.shares.toLocaleString()}주</div>
    <div class="text-slate-500 text-xs">평단 {Math.round(position.avgCost).toLocaleString()}</div>
  </div>
  <div class="text-right">
    <div>{Math.round(position.currentPrice).toLocaleString()}</div>
    <div class={`${colorCls} text-xs`}>{positive ? '+' : ''}{(r * 100).toFixed(1)}%</div>
  </div>
  <div class="text-right text-xs text-slate-500">
    {position.dcaPlan ? 'DCA 진행' : position.distPlan ? '분할 매도' : '보유'}
  </div>
</div>

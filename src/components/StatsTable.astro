---
interface Row {
  label: string;
  count: number;
  winRate: number | null;
  meanReturn: number | null;
  medianReturn?: number | null;
  pickRate: number | null;
}
interface Props {
  title: string;
  rows: Row[];
  highlightLabel?: string;
}
const { title, rows, highlightLabel } = Astro.props;

const fmtPct = (v: number | null, digits = 1) =>
  v == null ? 'N/A' : `${(v * 100).toFixed(digits)}%`;
const fmtReturn = (v: number | null) =>
  v == null ? 'N/A' : `${v >= 0 ? '+' : ''}${(v * 100).toFixed(2)}%`;
const returnColor = (v: number | null) =>
  v == null ? 'text-slate-400' : v > 0 ? 'text-emerald-600' : v < 0 ? 'text-rose-600' : 'text-slate-600';
---

<section class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
  <h2 class="mb-3 text-sm font-semibold text-slate-700">{title}</h2>
  <div class="overflow-x-auto">
    <table class="w-full text-xs">
      <thead>
        <tr class="border-b border-slate-200 text-left text-slate-500">
          <th class="py-2 pr-2 font-medium">구간</th>
          <th class="py-2 pr-2 text-right font-medium">건수</th>
          <th class="py-2 pr-2 text-right font-medium">진입률</th>
          <th class="py-2 pr-2 text-right font-medium">승률</th>
          <th class="py-2 text-right font-medium">평균 수익</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr
            class:list={[
              'border-b border-slate-100 last:border-0',
              r.label === highlightLabel ? 'bg-amber-50' : '',
            ]}
          >
            <td class="py-2 pr-2 font-medium text-slate-800">{r.label}</td>
            <td class="py-2 pr-2 text-right tabular-nums text-slate-700">{r.count}</td>
            <td class="py-2 pr-2 text-right tabular-nums text-slate-500">{fmtPct(r.pickRate, 1)}</td>
            <td class="py-2 pr-2 text-right tabular-nums text-slate-700">{fmtPct(r.winRate, 1)}</td>
            <td class={`py-2 text-right tabular-nums ${returnColor(r.meanReturn)}`}>
              {fmtReturn(r.meanReturn)}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

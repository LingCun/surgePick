---
import Base from '../layouts/Base.astro';
import FearGaugeCard from '../components/FearGaugeCard.astro';
import MarketMoodCard from '../components/MarketMoodCard.astro';
import OverallCard from '../components/OverallCard.astro';
import picksData from '../data/picks.json';
import regimeData from '../data/regime.json';
import backtestData from '../data/backtest.json';
import portfolioData from '../data/portfolio.json';
import { reasonKr } from '../lib/labels';

type Action = { date: string; action: string; ticker: string; name?: string; shares?: number; price?: number; reason?: string };
const todayActions: Action[] = ((picksData as any).actions ?? []) as Action[];
const picksAsOf = (picksData as any).asOf;
const { fearGauge, markets = [], overall, asOf: regimeAsOf } = regimeData;

const { initialCapital, equityCurve, metrics } = backtestData as any;
const FX = 1300;
const totalInitial = initialCapital.krInitial + initialCapital.usInitial * FX;
const lastEq = equityCurve[equityCurve.length - 1];
const totalCurrent = lastEq?.total ?? totalInitial;
const totalReturn = (totalCurrent / totalInitial - 1) * 100;
const positions: any[] = (portfolioData as any).positions ?? [];
const krCount = positions.filter((p) => p.market === 'KR').length;
const usCount = positions.filter((p) => p.market === 'US').length;

const asOf = (backtestData as any).asOf ?? regimeAsOf ?? picksAsOf;
---
<Base title="surgePick — 포트폴리오 + 시장 온도계" asOf={asOf}>
  <nav class="flex gap-3 text-sm py-2 px-4 border-b border-slate-800 mb-4">
    <a href="/" class="font-medium text-slate-100">홈</a>
    <a href="/portfolio" class="text-slate-400 hover:text-slate-200">포트폴리오</a>
    <a href="/watchlist" class="text-slate-400 hover:text-slate-200">관찰목록</a>
    <a href="/stats" class="text-slate-400 hover:text-slate-200">통계</a>
  </nav>

  <section class="mb-6 rounded-2xl bg-slate-900 border border-slate-800 p-4 space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-200">포트폴리오 요약</h2>
      <a href="/portfolio" class="text-xs text-sky-400 hover:text-sky-300">자세히 →</a>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <div class="text-xs text-slate-400">총 자산 (원화 환산)</div>
        <div class="text-lg font-bold tabular-nums">{Math.round(totalCurrent).toLocaleString()}원</div>
      </div>
      <div>
        <div class="text-xs text-slate-400">총 수익률</div>
        <div class={`text-lg font-bold tabular-nums ${totalReturn >= 0 ? 'text-rose-400' : 'text-sky-400'}`}>
          {totalReturn >= 0 ? '+' : ''}{totalReturn.toFixed(1)}%
        </div>
      </div>
      <div>
        <div class="text-xs text-slate-400">연복리수익률</div>
        <div class="text-lg font-bold tabular-nums">{(metrics.cagr * 100).toFixed(1)}%</div>
      </div>
      <div>
        <div class="text-xs text-slate-400">보유 종목</div>
        <div class="text-lg font-bold tabular-nums">
          {positions.length}
          <span class="text-xs text-slate-500 ml-1 font-normal">(KR {krCount} · US {usCount})</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-6 rounded-2xl bg-slate-900 border border-slate-800 p-4 space-y-3">
    <h2 class="text-sm font-semibold text-slate-200">오늘의 행동</h2>
    {todayActions.length === 0 ? (
      <p class="text-xs text-slate-500">오늘 매매 신호 없음.</p>
    ) : todayActions.map((a) => (
      <div class="flex items-center justify-between text-xs text-slate-300 gap-2">
        <span class={a.action === 'buy' ? 'text-emerald-400 font-medium w-10' : 'text-rose-400 font-medium w-10'}>
          {a.action === 'buy' ? '매수' : '매도'}
        </span>
        <span class="font-medium flex-1 truncate">{a.name ?? a.ticker}</span>
        {a.shares != null && <span>{a.shares}주</span>}
        {a.price != null && <span class="tabular-nums">{Math.round(a.price).toLocaleString()}</span>}
        {a.reason && <span class="text-slate-500 text-xs">{reasonKr(a.reason)}</span>}
      </div>
    ))}
  </section>

  <section class="space-y-4">
    <h2 class="text-base font-semibold flex items-center gap-2"><span aria-hidden="true">🌡️</span>지금 시장 어때?</h2>
    <FearGaugeCard {...fearGauge} />
    {markets.map((m) => <MarketMoodCard {...m} />)}
    <OverallCard {...overall} />
  </section>
</Base>

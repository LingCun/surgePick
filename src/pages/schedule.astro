---
export const prerender = true;
import Base from '../layouts/Base.astro';
import regimeData from '../data/regime.json';
import scheduleData from '../data/schedule.json';

const { asOf: regimeAsOf, asOfKR, asOfUS } = regimeData as any;
const { events = [], note } = scheduleData as { events: any[]; note?: string };

// 오늘 이후 + 중요(high) 일정만 + 날짜순 정렬
const today = new Date().toISOString().slice(0, 10);
const upcoming = events
  .filter((e) => e.date >= today && e.importance === 'high')
  .sort((a, b) => (a.date === b.date ? (a.time ?? '').localeCompare(b.time ?? '') : a.date.localeCompare(b.date)));

// 날짜별 그룹
const byDate = new Map<string, any[]>();
for (const e of upcoming) {
  if (!byDate.has(e.date)) byDate.set(e.date, []);
  byDate.get(e.date)!.push(e);
}

const fmtDate = (d: string) => {
  const date = new Date(d + 'T00:00:00Z');
  const weekdays = ['일', '월', '화', '수', '목', '금', '토'];
  return `${date.getUTCMonth() + 1}월 ${date.getUTCDate()}일 (${weekdays[date.getUTCDay()]})`;
};
const isToday = (d: string) => d === today;
const isThisWeek = (d: string) => {
  const e = new Date(d + 'T00:00:00Z');
  const t = new Date(today + 'T00:00:00Z');
  const diff = (e.getTime() - t.getTime()) / (1000 * 60 * 60 * 24);
  return diff >= 0 && diff < 7;
};

const importanceColor = {
  high: 'bg-rose-950/40 border-rose-700/50 text-rose-300',
  mid:  'bg-amber-950/40 border-amber-700/50 text-amber-300',
  low:  'bg-slate-800/40 border-slate-700/50 text-slate-300',
};
const categoryEmoji = {
  fed: '🏛️',
  bok: '🏦',
  macro: '📊',
  earnings: '💼',
  other: '📌',
};
const categoryLabel = {
  fed: 'Fed',
  bok: 'BOK',
  macro: '거시',
  earnings: '실적',
  other: '기타',
};
---
<Base title="surgePick — 일정" asOf={regimeAsOf} asOfKR={asOfKR} asOfUS={asOfUS}>
  <section class="space-y-6">
    <div class="space-y-2">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-cyan-300 to-sky-500 bg-clip-text text-transparent">일정</span>
      </h1>
      <p class="text-sm text-slate-400 leading-relaxed">
        한국·미국 증시에 영향이 큰 <span class="text-rose-300">중요 일정만</span> 추려서 보여줍니다. 모든 시각은 <span class="text-slate-200 font-medium">한국시간(KST)</span> 기준이에요. {note}
      </p>
    </div>

    <div id="schedule-filter" class="flex gap-2 items-center">
      <button data-mkt="all" class="sched-btn sched-active">전체</button>
      <button data-mkt="KR" class="sched-btn">🇰🇷 한국</button>
      <button data-mkt="US" class="sched-btn">🇺🇸 미국</button>
      <span class="ml-auto text-[11px] text-slate-400 flex items-center gap-1 shrink-0">
        <span aria-hidden="true">🕘</span>한국시간(KST)
      </span>
    </div>

    {upcoming.length === 0 && (
      <div class="bg-slate-900/40 border border-slate-800 rounded-xl p-8 text-center text-slate-400 text-sm">
        예정된 일정이 없습니다. 다음 라운드에 갱신될 예정입니다.
      </div>
    )}

    <div class="space-y-4">
      {[...byDate.entries()].map(([date, items]) => (
        <section
          data-day
          data-markets={[...new Set(items.map((i) => i.market))].join(',')}
          class={`bg-slate-900/40 border ${isToday(date) ? 'border-cyan-700/60 shadow-lg shadow-cyan-900/20' : 'border-slate-800'} rounded-xl overflow-hidden`}
        >
          <header class={`px-4 py-2.5 flex items-center justify-between ${isToday(date) ? 'bg-cyan-900/30' : 'bg-slate-900/40'}`}>
            <h2 class={`text-sm font-semibold ${isToday(date) ? 'text-cyan-300' : 'text-slate-300'}`}>
              {fmtDate(date)}
              {isToday(date) && <span class="ml-2 px-2 py-0.5 rounded-full bg-cyan-600 text-white text-[10px] font-bold align-middle">오늘</span>}
              {!isToday(date) && isThisWeek(date) && <span class="ml-2 text-[10px] text-cyan-400">이번 주</span>}
            </h2>
            <span class="text-[10px] text-slate-500">{items.length}건</span>
          </header>
          <ul class="divide-y divide-slate-800/40">
            {items.map((e) => (
              <li data-event data-market={e.market} class="px-4 py-3 flex items-start gap-3">
                <div class="text-xs text-slate-400 font-mono tabular-nums w-12 shrink-0 pt-0.5">{e.time ?? '—'}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-xs">{categoryEmoji[e.category] ?? '📌'}</span>
                    <span class={`px-1.5 py-0.5 text-[10px] rounded border ${importanceColor[e.importance] ?? importanceColor.low}`}>{categoryLabel[e.category] ?? e.category}</span>
                    <span class="text-[10px] text-slate-500">{e.market === 'KR' ? '🇰🇷' : '🇺🇸'}</span>
                  </div>
                  <div class="text-sm text-slate-200 mt-1 leading-snug">{e.title}</div>
                  {e.ticker && (
                    <a href={`/sim?ticker=${e.ticker}`} class="inline-block mt-1 text-[11px] text-cyan-400 hover:text-cyan-300 underline-offset-2 hover:underline">
                      {e.ticker.replace(/\.[A-Z]+$/, '')} 시뮬레이션 보기 →
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <p class="text-[11px] text-slate-500 text-center pt-4">
      일정은 변경될 수 있으며, 공식 발표(Fed/BOK/KOSTAT/IR)를 우선 참고하세요.
    </p>
  </section>
</Base>

<style is:global>
  .sched-btn {
    padding: 8px 16px;
    border-radius: 10px;
    background: rgb(30 41 59);
    color: rgb(148 163 184);
    font-size: 13px;
    font-weight: 600;
    transition: all 160ms ease;
    border: 1px solid transparent;
  }
  .sched-btn:hover {
    background: rgb(51 65 85);
    color: rgb(226 232 240);
  }
  .sched-btn.sched-active {
    background: linear-gradient(135deg, rgb(8 145 178), rgb(14 116 144));
    color: white;
    border-color: rgb(34 211 238);
  }
</style>

<script>
  const filterBar = document.getElementById('schedule-filter');
  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-mkt]') as HTMLButtonElement | null;
      if (!btn) return;
      const mkt = btn.dataset.mkt;
      filterBar.querySelectorAll('[data-mkt]').forEach((b) => b.classList.toggle('sched-active', b === btn));

      const events = document.querySelectorAll('[data-event]');
      events.forEach((el) => {
        const m = (el as HTMLElement).dataset.market;
        (el as HTMLElement).style.display = (mkt === 'all' || m === mkt) ? '' : 'none';
      });

      // 날짜 그룹: 모든 이벤트 숨겨졌으면 그 날짜도 숨김
      document.querySelectorAll('[data-day]').forEach((day) => {
        const visible = [...day.querySelectorAll('[data-event]')].some((ev) => (ev as HTMLElement).style.display !== 'none');
        (day as HTMLElement).style.display = visible ? '' : 'none';
      });
    });
  }
</script>

---
import Base from '../layouts/Base.astro';
import TickerSearch from '../components/TickerSearch.astro';
import SimController from '../components/SimController.astro';
import regimeData from '../data/regime.json';
export const prerender = false;
const { asOf: regimeAsOf } = regimeData;
---
<Base title="surgePick — 시뮬레이션" asOf={regimeAsOf}>
  <section class="space-y-6">
    <div class="space-y-2">
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-cyan-300 to-sky-500 bg-clip-text text-transparent">종목 시뮬레이션</span>
      </h1>
      <p class="text-sm text-slate-400 leading-relaxed">
        종목과 기간을 고르면, 과거 한 달의 실제 흐름과 함께 유사 시장 국면의 평균 궤적을 평균해 1·2·3개월 예측선을 그립니다.
      </p>
    </div>

    <TickerSearch />

    <div id="horizon-picker" class="bg-slate-900/40 border border-slate-800 rounded-xl p-4 space-y-3">
      <div class="text-xs uppercase tracking-wide text-slate-500 font-semibold">예측 기간</div>
      <div class="grid grid-cols-3 gap-2">
        <button data-hz="30" class="hz-btn hz-active">
          <span class="text-lg font-bold">1M</span>
          <span class="text-[10px] opacity-75">1달</span>
        </button>
        <button data-hz="60" class="hz-btn">
          <span class="text-lg font-bold">2M</span>
          <span class="text-[10px] opacity-75">2달</span>
        </button>
        <button data-hz="90" class="hz-btn">
          <span class="text-lg font-bold">3M</span>
          <span class="text-[10px] opacity-75">3달</span>
        </button>
      </div>
    </div>

    <div id="sim-result" class="hidden space-y-6"></div>
    <SimController />
  </section>
</Base>

<style is:global>
  .hz-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 12px 8px;
    border-radius: 10px;
    background: rgb(30 41 59);
    color: rgb(148 163 184);
    font-weight: 600;
    transition: all 160ms ease;
    border: 1px solid transparent;
  }
  .hz-btn:hover {
    background: rgb(51 65 85);
    color: rgb(226 232 240);
  }
  .hz-btn.hz-active {
    background: linear-gradient(135deg, rgb(8 145 178), rgb(14 116 144));
    color: white;
    border-color: rgb(34 211 238);
    box-shadow: 0 4px 14px -2px rgba(34, 211, 238, 0.35);
  }
</style>
